  "components": {
    "schemas": {
      "ApproveRejectDto": {
        "type": "object",
        "properties": {
          "reason": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "OrderStatus": {
        "enum": [
          0,
          1,
          2,
          3,
          4,
          5,
          6,
          7,
          8
        ],
        "type": "integer",
        "format": "int32"
      },
      "UpdateOrderStatusDto": {
        "required": [
          "newStatus",
          "reason"
        ],
        "type": "object",
        "properties": {
          "newStatus": {
            "$ref": "#/components/schemas/OrderStatus"
          },
          "reason": {
            "minLength": 5,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UpdateUserDto": {
        "required": [
          "fullName",
          "isActive",
          "phoneNo"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          },
          "phoneNo": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
